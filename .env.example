# Copy this file to `.env` in this directory (server/.env) and fill in real
# values. Never commit the real `.env` file. This file documents variable
# names only — no real secrets/credentials belong here.

NODE_ENV=development
PORT=4002

# --- Database (Hostinger-hosted MySQL) ---
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# --- Auth (JWT) ---
JWT_SECRET=changeme_generate_a_random_string
JWT_EXPIRES_IN=7d

# --- Google OAuth (fill in before enabling Google login) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4002/api/auth/google/callback

# --- AWS S3 (fill in before enabling image upload) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=

# --- Gemini (fill in before enabling the product-finding assistant) ---
# GEMINI_API_KEY=
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
# GEMINI_CHAT_MODEL=gemini-2.5-flash

# --- Cookies / CORS ---
# CLIENT_ORIGIN must match the origin the separate frontend repo is served
# from (e.g. http://localhost:5173 in dev, or the production client domain).
# It is used both for the post-OAuth redirect and as the exact (non-wildcard)
# allowed CORS origin, so it must be an exact match with no trailing slash —
# e.g. in production (frontend on anthony.isseylab.com, API on
# anthony-api.isseylab.com) set CLIENT_ORIGIN=https://anthony.isseylab.com
#
# COOKIE_DOMAIN controls the cookie's Domain attribute. In production, the
# frontend and API live on separate subdomains of isseylab.com, so this must
# be set to the shared parent domain with a leading dot, e.g.
# COOKIE_DOMAIN=.isseylab.com, so cookies set by the API are readable on both
# anthony.isseylab.com and anthony-api.isseylab.com.
COOKIE_DOMAIN=localhost
CLIENT_ORIGIN=http://localhost:5173

# --- CSRF ---
CSRF_SECRET=changeme_generate_a_random_string

# --- Business config ---
DEFAULT_LOW_STOCK_THRESHOLD=5

# --- SEO/GEO worker (scripts/seo-geo-worker.js) ---
# Generates via Gemini (GEMINI_API_KEY above) — no other setup needed, runs
# headless anywhere including Docker. All optional — defaults shown.
# SEO_WORKER_POLL_INTERVAL_MS=20000
# SEO_WORKER_BATCH_SIZE=3
